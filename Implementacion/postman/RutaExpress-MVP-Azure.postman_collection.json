          }
        },
        {
          "name": "E7 — Evidencia hash invalido (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sha256\": \"invalid\"\n}"
            },
            "url": "{{aws_alb_base_url}}/deliveries/123/evidence"
          }
        }
      ]
    }
  ]
