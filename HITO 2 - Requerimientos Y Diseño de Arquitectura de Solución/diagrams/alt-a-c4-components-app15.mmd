        Component(ui, "UI Entrega", "Flutter/React Native", "Pantallas conductor")
        Component(offline, "Módulo Offline", "SQLite AES-256", "Cola local eventos/evidencias")
        Component(taxonomy, "Taxonomía Excepciones", "Mobile lib", "Motivos obligatorios")
    }

    Container_Boundary(aws_backend, "Backend AWS — ECS Fargate") {
        Component(api, "API Entrega", ".NET/Node", "REST sync")
