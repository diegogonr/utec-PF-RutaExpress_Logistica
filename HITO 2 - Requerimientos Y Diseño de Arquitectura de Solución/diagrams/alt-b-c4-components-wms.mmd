C4Component
    title Alternativa B — Nivel 3: WMS Cloud (INI-02)

    Container_Boundary(wms, "WMS Cloud — Azure AKS") {
        Component(reserva, "Servicio Reserva", ".NET", "Stock idempotente")
        Component(picking, "Servicio Picking", ".NET", "Olas picking")
        Component(reconciliador, "Reconciliador CD", ".NET", "Modo degradado")
        Component(local_pub, "Publicador Azure", ".NET", "Solo bus_az")
    }

    Container(bus_az, "Azure Event Hubs (PLT-03-AZ)", "Dominio Azure")
    Container(router, "Enrutador Multinube", "AKS")
    Container(tms, "TMS (APP-11)", "AKS")

    Rel(reserva, local_pub, "Events")
    Rel(picking, local_pub, "Events")
    Rel(reconciliador, local_pub, "Events")
    Rel(local_pub, bus_az, "Publish")
    Rel(bus_az, router, "Forward cross-cloud")
    Rel(router, tms, "Subscribe via bus_az")
