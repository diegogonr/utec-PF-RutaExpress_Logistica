C4Component
    title Alternativa B — Nivel 3: Componentes App Conductores (INI-03)

    Container_Boundary(mobile, "App de Conductores (APP-15) — Mobile") {
        Component(ui, "UI Entrega", "Flutter/React Native", "Pantallas conductor")
        Component(offline, "Módulo Offline", "SQLite AES-256", "Cola local eventos/evidencias")
        Component(taxonomy, "Taxonomía Excepciones", "Mobile lib", "Motivos obligatorios")
    }

    Container_Boundary(aws_backend, "Backend AWS — ECS Fargate") {
        Component(api, "API Entrega", ".NET", "REST sync")
        Component(sync, "Servicio Sync Atómico", "Worker", "Upload evidencias + idempotencia")
        Component(kin_prod, "Productor Kinesis", "AWS SDK", "Eventos tracking")
    }

    Container(s3, "Almacenamiento Evidencias (APP-16)", "S3")
    Container(kinesis, "AWS Kinesis", "Data Streams")
    Container(rule, "Regla nativa AWS", "EventBridge rule", "Kinesis → EventBridge")
