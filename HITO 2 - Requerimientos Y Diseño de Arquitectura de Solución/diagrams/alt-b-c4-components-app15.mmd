    Rel(sync, s3, "PUT atómico")
    Rel(sync, kin_prod, "Emit")
    Rel(kin_prod, kinesis, "PutRecord")
    Rel(kinesis, rule, "Stream")
    Rel(rule, bus_aws, "PutEvents")
    Rel(bus_aws, router, "Forward")
