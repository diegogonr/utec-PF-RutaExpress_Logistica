C4Component
    title Alternativa B — Nivel 3: Enrutador de Eventos (INI-01)

    Container_Boundary(router, "Enrutador de Eventos — AKS") {
        Component(ingress_az, "Adaptador Azure Event Hubs", "Azure Function", "Consume PLT-03-AZ")
        Component(ingress_aws, "Adaptador EventBridge", "Lambda / Connect", "Consume PLT-03-AWS")
        Component(translator, "Traductor Canónico", ".NET", "Mapeo esquema v1 cross-cloud")
        Component(dedup, "Deduplicador", "Redis Cluster", "Idempotencia eventId")
        Component(egress_gcp, "Publicador Pub/Sub", "Connect", "Forward a GCP")
        Component(egress_portal, "Dispatcher SaaS", "Worker", "Webhooks APP-18")
        Component(dlq, "Dead Letter Queue", "SQS + Storage", "Eventos fallidos")
    }

    Container(bus_az, "Azure Event Hubs", "PLT-03-AZ")
    Container(bus_aws, "Amazon EventBridge", "PLT-03-AWS")
    Container(bus_gcp, "Google Pub/Sub", "PLT-03-GCP")
    Container(schema, "Esquemas canónicos", "Azure Blob Storage + Function")

    Rel(bus_az, ingress_az, "Consume")
    Rel(bus_aws, ingress_aws, "Consume")
    Rel(ingress_az, translator, "Raw events")
    Rel(ingress_aws, translator, "Raw events")
    Rel(schema, translator, "Validate")
    Rel(translator, dedup, "Canonical")
    Rel(dedup, egress_gcp, "Route ML")
    Rel(dedup, egress_portal, "Route B2B")
    Rel(translator, dlq, "On failure")
    Rel(egress_gcp, bus_gcp, "Publish")
